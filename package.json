{
  "name": "grind-workout-app",
  "version": "1.0.0",
  "type": "module",
  "description": "GRIND - Home Workout Engine with Firebase to Neon PostgreSQL migration",
  "main": "server/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "start": "npm run server",
    "db:init": "psql $DATABASE_URL -f server/db/init.sql",
    "dev:all": "npm run server:dev & npm run dev"
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
