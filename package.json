{
  "name": "grind-workout-app",
  "version": "1.0.0",
  "description": "Workout tracking app with Express and Neon PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "db:init": "node -e \"const fs=require('fs');const {Pool}=require('pg');const pool=new Pool({connectionString:process.env.DATABASE_URL,ssl:{rejectUnauthorized:false}});pool.query(fs.readFileSync('db/init.sql','utf8')).then(()=>{console.log('Schema created');pool.end()}).catch(e=>{console.error(e);pool.end()})\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  }
}
